    "description": "Count of distinct products sold",
    "format": "Whole Number",
    "used_in_pages": [
      "Page 2"
    ],
    "used_in_visuals": [
      "cardVisual"
    ]
  },
  {
    "name": "Store Count",
    "table": "MavenMarket_Measures",
    "expression": "Store Count = DISTINCTCOUNT(MavenMarket_Transactions[store_id])",
